{
  "name": "@k8o/oxc-config",
  "version": "0.1.3",
  "description": "Shareable oxlint + oxfmt configurations for TypeScript / React / Next.js / Backend / Tailwind / Test projects.",
  "keywords": [
    "config",
    "fmt",
    "k8o",
    "lint",
    "nextjs",
    "oxc",
    "oxfmt",
    "oxlint",
    "react",
    "tailwindcss",
    "typescript"
  ],
  "homepage": "https://github.com/k35o/oxc-config#readme",
  "bugs": "https://github.com/k35o/oxc-config/issues",
  "license": "MIT",
  "author": "k8o (https://github.com/k35o)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/oxc-config.git"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./base": {
      "types": "./dist/configs/base.d.mts",
      "default": "./dist/configs/base.mjs"
    },
    "./typescript": {
      "types": "./dist/configs/typescript.d.mts",
      "default": "./dist/configs/typescript.mjs"
    },
    "./react": {
      "types": "./dist/configs/react.d.mts",
      "default": "./dist/configs/react.mjs"
    },
    "./nextjs": {
      "types": "./dist/configs/nextjs.d.mts",
      "default": "./dist/configs/nextjs.mjs"
    },
    "./backend": {
      "types": "./dist/configs/backend.d.mts",
      "default": "./dist/configs/backend.mjs"
    },
    "./test": {
      "types": "./dist/configs/test.d.mts",
      "default": "./dist/configs/test.mjs"
    },
    "./tailwind": {
      "types": "./dist/configs/tailwind.d.mts",
      "default": "./dist/configs/tailwind.mjs"
    },
    "./regexp": {
      "types": "./dist/configs/regexp.d.mts",
      "default": "./dist/configs/regexp.mjs"
    },
    "./storybook": {
      "types": "./dist/configs/storybook.d.mts",
      "default": "./dist/configs/storybook.mjs"
    },
    "./playwright": {
      "types": "./dist/configs/playwright.d.mts",
      "default": "./dist/configs/playwright.mjs"
    },
    "./fmt": {
      "types": "./dist/configs/fmt.d.mts",
      "default": "./dist/configs/fmt.mjs"
    },
    "./base.oxlintrc.json": "./dist/base.oxlintrc.json",
    "./typescript.oxlintrc.json": "./dist/typescript.oxlintrc.json",
    "./react.oxlintrc.json": "./dist/react.oxlintrc.json",
    "./nextjs.oxlintrc.json": "./dist/nextjs.oxlintrc.json",
    "./backend.oxlintrc.json": "./dist/backend.oxlintrc.json",
    "./tailwind.oxlintrc.json": "./dist/tailwind.oxlintrc.json",
    "./regexp.oxlintrc.json": "./dist/regexp.oxlintrc.json",
    "./fmt.oxfmtrc.json": "./dist/fmt.oxfmtrc.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack && node scripts/build-json-configs.mjs",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "check:write": "vp check --fix",
    "check:package": "publint --strict && attw --pack . --profile esm-only",
    "typecheck": "tsc --noEmit",
    "preview": "vp-inspect previews/nextjs",
    "preview:base": "vp-inspect previews/base",
    "preview:typescript": "vp-inspect previews/typescript",
    "preview:react": "vp-inspect previews/react",
    "preview:nextjs": "vp-inspect previews/nextjs",
    "preview:backend": "vp-inspect previews/backend",
    "preview:test": "vp-inspect previews/test",
    "preview:tailwind": "vp-inspect previews/tailwind",
    "preview:regexp": "vp-inspect previews/regexp",
    "preview:build": "node scripts/build-previews.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm check && pnpm test && changeset publish",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@oxlint/plugins": "1.71.0",
    "@types/node": "24.13.2",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-regexp": "3.1.1",
    "eslint-plugin-storybook": "10.4.6",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tailwindcss": "1.3.3",
    "publint": "0.3.21",
    "typescript": "6.0.3",
    "vite-plus": "0.2.1",
    "vite-plus-inspector": "0.1.0",
    "wrangler": "4.105.0"
  },
  "peerDependencies": {
    "eslint-plugin-playwright": ">=2.0.0",
    "eslint-plugin-regexp": ">=3.0.0",
    "eslint-plugin-storybook": ">=10.0.0",
    "oxfmt": ">=0.43.0",
    "oxlint": ">=1.71.0",
    "oxlint-tailwindcss": ">=1.3.2",
    "oxlint-tsgolint": ">=0.23.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-playwright": {
      "optional": true
    },
    "eslint-plugin-regexp": {
      "optional": true
    },
    "eslint-plugin-storybook": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "oxlint-tailwindcss": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@11.9.0"
}
