{
  "name": "@k35o/oxc-config",
  "version": "0.1.0",
  "description": "Shareable oxlint + oxfmt configurations for TypeScript / React / Next.js / Backend / Tailwind / Test projects.",
  "keywords": [
    "config",
    "fmt",
    "k8o",
    "lint",
    "nextjs",
    "oxc",
    "oxfmt",
    "oxlint",
    "react",
    "tailwindcss",
    "typescript"
  ],
  "homepage": "https://github.com/k35o/oxc-config#readme",
  "bugs": "https://github.com/k35o/oxc-config/issues",
  "license": "MIT",
  "author": "k8o (https://github.com/k35o)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/oxc-config.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./base": {
      "import": {
        "types": "./dist/configs/base.d.mts",
        "default": "./dist/configs/base.mjs"
      }
    },
    "./typescript": {
      "import": {
        "types": "./dist/configs/typescript.d.mts",
        "default": "./dist/configs/typescript.mjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/configs/react.d.mts",
        "default": "./dist/configs/react.mjs"
      }
    },
    "./nextjs": {
      "import": {
        "types": "./dist/configs/nextjs.d.mts",
        "default": "./dist/configs/nextjs.mjs"
      }
    },
    "./backend": {
      "import": {
        "types": "./dist/configs/backend.d.mts",
        "default": "./dist/configs/backend.mjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/configs/test.d.mts",
        "default": "./dist/configs/test.mjs"
      }
    },
    "./tailwind": {
      "import": {
        "types": "./dist/configs/tailwind.d.mts",
        "default": "./dist/configs/tailwind.mjs"
      }
    },
    "./fmt": {
      "import": {
        "types": "./dist/configs/fmt.d.mts",
        "default": "./dist/configs/fmt.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "check:write": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@oxlint/plugins": "1.58.0",
    "@types/node": "24.12.2",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tailwindcss": "0.6.1",
    "typescript": "6.0.3",
    "vite-plus": "0.1.16"
  },
  "peerDependencies": {
    "oxfmt": ">=0.43.0",
    "oxlint": ">=1.58.0",
    "oxlint-tailwindcss": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "oxlint-tailwindcss": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@10.33.0"
}
